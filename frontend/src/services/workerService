import api from "../api/axios";

export const getWorkers = async () => {
  const res = await api.get("/api/worker");
  return res.data;
};

export const createWorker = async (payload) => {
  return api.post("/api/worker/add", payload);
};

export const getWorkerById = async (id) => {
  const res = await api.get(`/api/worker/${id}`);
  return res.data;
};

export const updateWorker = async (id, payload) => {
  return api.put(`/api/worker/${id}/edit`, payload);
};

export const deleteWorker = async (id) => {
  return api.delete(`/api/worker/${id}`);
};

export const assignProjectToWorker = async (workerId, payload) => {
  return api.post(`/api/worker/${workerId}/assign-project`, payload);
};
